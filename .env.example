# =============================================================================
# SETUP (once)
# 1. Copy this file:  copy .env.example .env
# 2. Create a Firebase project: https://console.firebase.google.com → Add project
# 3. Add a Web app: Project settings (gear) → Your apps → Web </> → Register app
# 4. Copy the firebaseConfig values below (apiKey, authDomain, projectId, appId)
# 5. Enable Authentication: Build → Authentication → Get started → Email/Password ON
# 6. Restart Expo: npx expo start --clear  (env is read at startup)
#
# Optional — Google Sign-In:
# - Same Firebase project → Authentication → Sign-in method → Google → Enable
# - Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# - Web client ID → EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID
# - For Android (Expo Go): create Android OAuth client with package host.exp.exponent
#   and SHA-1 from https://docs.expo.dev/guides/google-authentication/
#   → EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID
# =============================================================================

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Optional — defaults to {PROJECT_ID}.appspot.com for Storage
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Optional — public legal URLs for Play Store / website (HTTPS). Shown in-app when set.
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://example.com/privacy
# EXPO_PUBLIC_TERMS_OF_USE_URL=https://example.com/terms
