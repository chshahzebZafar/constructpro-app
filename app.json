{
  "expo": {
    "name": "ConstructPro",
    "slug": "constructpro",
    "scheme": "constructpro",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/Icons/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Icons/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3A5C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digiqraft.constructpro",
      "buildNumber": "2"
    },
    "android": {
      "package": "com.digiqraft.constructpro",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCVPksIZQC1a5er9HchMnGfyMDJsXGNwR4"
        }
      },
      "softwareKeyboardLayoutMode": "resize",
      "notification": {
        "icon": "./assets/Icons/icon.png",
        "color": "#1B3A5C"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/Icons/adaptive-icon.png",
        "backgroundColor": "#1B3A5C"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "name": "ConstructPro",
      "shortName": "ConstructPro",
      "favicon": "./assets/Icons/favicon.png",
      "themeColor": "#1B3A5C",
      "backgroundColor": "#1B3A5C"
    },
    "plugins": [
      "expo-router",
      [
        "@sentry/react-native/expo",
        {
          "organization": "shahzeb",
          "project": "constructpro"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ConstructPro uses your location to show local weather on your home screen."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/Icons/splash-icon.png",
          "backgroundColor": "#1B3A5C",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ConstructPro to attach photos to your punch list.",
          "cameraPermission": "Allow ConstructPro to take photos for punch list items."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/Icons/icon.png",
          "color": "#1B3A5C"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd825cbc-bdec-46ad-a2eb-e0ab5fe950e3"
      }
    },
    "owner": "shahzeb"
  }
}
